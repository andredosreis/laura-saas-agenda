# =============================================
# LAURA SAAS FRONTEND - VARIÁVEIS DE AMBIENTE
# =============================================
# Copie este arquivo para .env e preencha os valores

# =============================================
# API BACKEND
# =============================================
# Local development
# VITE_API_URL=http://localhost:5000/api

# Production (substitua pela URL do seu backend no Vercel)
VITE_API_URL=https://seu-backend.vercel.app/api

# =============================================
# IDENTIFICAÇÃO VISUAL DO AMBIENTE (OPCIONAL)
# =============================================
# Substitui o badge automático (PRODUÇÃO em builds de produção; DEV localmente).
# Útil para identificar ambientes adicionais, por exemplo:
# VITE_ENV_LABEL=STAGING
