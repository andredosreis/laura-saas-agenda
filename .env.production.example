# ============================================================================
# Marcai — .env de produção (VPS Contabo, docker-compose.prod.yml)  [ADR-023]
# ----------------------------------------------------------------------------
# Copiar para `.env` no servidor e preencher. NUNCA commitar o .env real.
# Este ficheiro é partilhado (env_file) pelo backend E pelo ia-service:
# por isso INTERNAL_SERVICE_TOKEN é garantidamente idêntico nos dois.
#
# As URLs internas (IA_SERVICE_URL, EVOLUTION_API_URL, MARCAI_API_URL, REDIS_URL)
# são definidas pela topologia no docker-compose.prod.yml — NÃO as pôr aqui.
# ============================================================================

# ---- Domínios (para o nginx/compose) ----------------------------------------
# Usados na config nginx (substituir os placeholders) e no SERVER_URL do Evolution.
WHATSAPP_DOMAIN=wa.exemplo.pt

# ---- Segredo partilhado backend <-> ia-service ------------------------------
# 64 chars hex. Gerar com: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# ---- Base de dados (MongoDB Atlas — mantém-se, região UE) -------------------
MONGODB_URI=mongodb+srv://utilizador:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_PREFIX=marcai

# ---- Redis (BullMQ — container interno) -------------------------------------
# A password é usada pelo redis e interpolada no REDIS_URL do compose.
# Gerar com: openssl rand -hex 24
REDIS_PASSWORD=

# ---- JWT --------------------------------------------------------------------
JWT_SECRET=
JWT_REFRESH_SECRET=

# ---- Frontend (Vercel) ------------------------------------------------------
FRONTEND_URL=https://laura-saas-agenda-mfqt.vercel.app

# ---- Evolution API (WhatsApp) ----------------------------------------------
EVOLUTION_API_KEY=
# Instância default (se aplicável ao teu fluxo single-instance)
EVOLUTION_INSTANCE=
# Segredo do webhook Evolution -> backend (header de validação de origem)
EVOLUTION_WEBHOOK_SECRET=

# ---- LLM (ia-service) -------------------------------------------------------
# Modelo vencedor validado em produção: gemini-3.1-flash-lite
LLM_PROVIDER=gemini
AGENT_MODEL_GEMINI=gemini-3.1-flash-lite
GOOGLE_API_KEY=
# Opcionais (só se LLM_PROVIDER mudar):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Marcai <no-reply@exemplo.pt>
EMAIL_REQUIRED=true

# ---- Web Push (VAPID) -------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@exemplo.pt

# ---- Observabilidade --------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=info

# ---- LangSmith (opcional — tracing do ia-service) ---------------------------
# Endpoint EU obrigatório se ligado (ver memória project_langsmith_setup)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=marcai-ia-service
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# ---- CRON de lembretes de parcela (opcional — têm defaults no código) -------
# LEMBRETE_PARCELA_CRON=true
# LEMBRETE_PARCELA_DIAS_ANTES=3
