# =============================================
# LAURA SAAS - VARIÁVEIS DE AMBIENTE (EXEMPLO)
# =============================================
# Copie este arquivo para .env e preencha os valores

# =============================================
# MONGODB
# =============================================
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster.mongodb.net/lauraDB?retryWrites=true&w=majority

# Credencial READ-ONLY do painel super-admin (ADR-024 Gate 4b). Utilizador Mongo
# SEPARADO, role só de leitura. Fail-closed: GET /admin/tenants/:id/uso lança sem ela
# (nunca usa a conexão principal). Em testes, aponta ao memory-server automaticamente.
MONGO_TENANT_RO_URI=mongodb+srv://ro_user:SUA_SENHA@cluster.mongodb.net/?retryWrites=true&w=majority

# =============================================
# JWT (AUTENTICAÇÃO)
# =============================================
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua-chave-secreta-muito-segura-aqui
JWT_REFRESH_SECRET=outra-chave-secreta-para-refresh-token

# =============================================
# OPENAI (IA)
# =============================================
OPENAI_API_KEY=sk-proj-...

# =============================================
# WHATSAPP — Evolution API (v2, self-hosted) — ACTUAL
# =============================================
EVOLUTION_API_URL=https://sua-instancia-evolution
EVOLUTION_API_KEY=sua_api_key_global
EVOLUTION_INSTANCE=marcai
# Secret validado no webhook (header `apikey`) — comparação timing-safe, fail-closed
EVOLUTION_WEBHOOK_SECRET=token-secreto-do-webhook

# =============================================
# WEB PUSH (VAPID)
# =============================================
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=sua_chave_publica
VAPID_PRIVATE_KEY=sua_chave_privada
VAPID_SUBJECT=mailto:seu@email.com

# =============================================
# AMBIENTE
# =============================================
NODE_ENV=development
PORT=5000

# =============================================
# FRONTEND URL
# =============================================
FRONTEND_URL=http://localhost:5173

# =============================================
# EMAIL (RESEND — HTTP API)
# =============================================
# API key da Resend (https://resend.com/api-keys) — formato re_xxxxxxxxx
# Necessária em produção. Em dev sem esta var, emails são logados em vez de enviados.
# Resend usa HTTPS e contorna bloqueios SMTP de PaaS (Render, Heroku, Vercel).
RESEND_API_KEY=re_your_api_key_here

# Endereço "from" — tem de ser de um domínio verificado em https://resend.com/domains.
# Para teste podes usar onboarding@resend.dev (só envia para o teu email registado).
EMAIL_FROM=Marcai <noreply@teu-dominio-verificado.com>

# Opcional: se true, servidor falha startup quando RESEND_API_KEY em falta.
# EMAIL_REQUIRED=false

# =============================================
# STRIPE (PAGAMENTOS - FUTURO)
# =============================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================
# ia-service (Phase 2+)
# =============================================
IA_SERVICE_URL=http://localhost:8000
IA_SERVICE_ENABLED=true
INTERNAL_SERVICE_TOKEN=dev-token-change-in-production

# =============================================
# Aviso de saúde da ligação WhatsApp (Evolution)
# =============================================
# Destinatário do email de alerta (vazio = só Sentry). Ex: andredosreis@gmail.com
ALERT_EMAIL=
# URL do Manager da Evolution para o runbook do email (ex: https://wa.<host>.sslip.io/manager/)
EVOLUTION_MANAGER_URL=
# Poller de saúde: 'off' desliga a feature toda
EVOLUTION_HEALTH_CRON=
EVOLUTION_HEALTH_CRON_SCHEDULE=*/5 * * * *
EVOLUTION_HEALTH_CONFIRM_MS=180000
EVOLUTION_HEALTH_DAILY_MS=86400000
EVOLUTION_HEALTH_RECHECK_DEBOUNCE_MS=60000
