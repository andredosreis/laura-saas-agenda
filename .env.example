# =============================================
# LAURA SAAS - VARIÁVEIS DE AMBIENTE (EXEMPLO)
# =============================================
# Copie este arquivo para .env e preencha os valores

# =============================================
# MONGODB
# =============================================
MONGODB_URI=mongodb+srv://SEU_USUARIO:SUA_SENHA@cluster.mongodb.net/lauraDB?retryWrites=true&w=majority

# =============================================
# JWT (AUTENTICAÇÃO)
# =============================================
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sua-chave-secreta-muito-segura-aqui
JWT_REFRESH_SECRET=outra-chave-secreta-para-refresh-token

# =============================================
# OPENAI (IA)
# =============================================
OPENAI_API_KEY=sk-proj-...

# =============================================
# Z-API (WHATSAPP)
# =============================================
ZAPI_INSTANCE_ID=seu_instance_id
ZAPI_TOKEN=seu_token
ZAPI_WEBHOOK_TOKEN=token-secreto-configurado-no-dashboard-zapi

# =============================================
# WEB PUSH (VAPID)
# =============================================
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=sua_chave_publica
VAPID_PRIVATE_KEY=sua_chave_privada
VAPID_SUBJECT=mailto:seu@email.com

# =============================================
# AMBIENTE
# =============================================
NODE_ENV=development
PORT=5000

# =============================================
# FRONTEND URL
# =============================================
FRONTEND_URL=http://localhost:5173

# =============================================
# EMAIL (RESEND — HTTP API)
# =============================================
# API key da Resend (https://resend.com/api-keys) — formato re_xxxxxxxxx
# Necessária em produção. Em dev sem esta var, emails são logados em vez de enviados.
# Resend usa HTTPS e contorna bloqueios SMTP de PaaS (Render, Heroku, Vercel).
RESEND_API_KEY=re_your_api_key_here

# Endereço "from" — tem de ser de um domínio verificado em https://resend.com/domains.
# Para teste podes usar onboarding@resend.dev (só envia para o teu email registado).
EMAIL_FROM=Marcai <noreply@teu-dominio-verificado.com>

# Opcional: se true, servidor falha startup quando RESEND_API_KEY em falta.
# EMAIL_REQUIRED=false

# =============================================
# STRIPE (PAGAMENTOS - FUTURO)
# =============================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
